olumn":1},"end":{"line":9,"column":1}},"key":"kwPHsecGaP"}],"key":"wvuf7udJxh"},{"type":"paragraph","position":{"start":{"line":11,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"🖐️ Conservation is challenging at best, exacerbated by climate change and multiple resource demands. It requires a multidisciplinary approach that taxes any organization’s capacity.","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"enPm43CZ13"},{"type":"break","key":"GjjwYnC4YT"},{"type":"text","value":"\n🖐️ Conservation organizations rarely have the time or capacity to measure success and incorporate learning into their project implementation. Data generation, management, and analysis are increasingly important but challenging.","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"V0qLPiamm6"},{"type":"break","key":"tbObJGe6L5"},{"type":"text","value":"\n🖐️ Solutions for geospatial analysis, collaborative leadership, and communications are not geared toward conservation organizations.","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"inRNPBUtmq"}],"key":"HAt5xPTB07"},{"type":"heading","depth":2,"position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"text","value":"Value Proposition","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"ywmRLcGGd1"}],"identifier":"value-proposition","label":"Value Proposition","html_id":"value-proposition","implicit":true,"key":"rPvI5aw1Rd"},{"type":"paragraph","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"link","url":"http://3point.xyz","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"text","value":"3point.xyz","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"OrCyuYjffw"}],"urlSource":"http://3point.xyz","key":"E2vtkGR5C5"},{"type":"text","value":" offers the following solutions to conservation problems:","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"aKrR3Wvtf6"}],"key":"EVD7AGkhOb"},{"type":"paragraph","position":{"start":{"line":18,"column":1},"end":{"line":20,"column":1}},"children":[{"type":"text","value":"🎯 Integrated tech with qualitative methods. ","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"Pq2F8tVEgJ"},{"type":"break","key":"IanSimc3nW"},{"type":"text","value":"\n🎯 Triangulation of data, learning, and collaboration.","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"i4ILPaFbTv"},{"type":"break","key":"KAVeOj0SLn"},{"type":"text","value":"\n🎯 Cost-effective success measurement and learning.","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"JwvLDyz3xj"}],"key":"W2lSdODj39"},{"type":"heading","depth":2,"position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"children":[{"type":"text","value":"Expectations","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"obf9XxVrDS"}],"identifier":"expectations","label":"Expectations","html_id":"expectations","implicit":true,"key":"ktCwGs8XaY"},{"type":"paragraph","position":{"start":{"line":23,"column":1},"end":{"line":25,"column":1}},"children":[{"type":"text","value":"✨ We’ll have an initial meeting to discuss your needs and outline how to work together to achieve your goals.","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"uqlWO6eCRp"},{"type":"break","key":"xEn36aFfX4"},{"type":"text","value":"\n✨ We’ll tailor a bespoke design to meet your organization and constituency’s needs.","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"zSOyYIWWG6"},{"type":"break","key":"mOwngikzfi"},{"type":"text","value":"\n✨ Finally, we’ll integrate cutting-edge conservation, climate, and behavior change science to design a strategy you can successfully implement and replicate!","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"Tu9Du4gQv1"}],"key":"HBpCJDDR6n"},{"type":"heading","depth":2,"position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"children":[{"type":"text","value":"Qualifications","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"sUpdMQni1a"}],"identifier":"qualifications","label":"Qualifications","html_id":"qualifications","implicit":true,"key":"jM1Z91i94d"},{"type":"paragraph","position":{"start":{"line":28,"column":1},"end":{"line":28,"column":1}},"children":[{"type":"text","value":"See CV, bio, and other sections for more details on qualifications.","position":{"start":{"line":28,"column":1},"end":{"line":28,"column":1}},"key":"lgVOKL9OeE"}],"key":"DgZjW5jIbG"},{"type":"paragraph","position":{"start":{"line":30,"column":1},"end":{"line":32,"column":1}},"children":[{"type":"text","value":"🌎 Vance Russell has nearly 40 years of experience managing program landscapes and providing technical leadership in forest ecology, remote sensing, data science, rewilding, climate change adaptation, biodiversity conservation, agriculture, restoration, and natural resources management.","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"key":"mvwyDvH1nK"},{"type":"break","key":"OULig6yYLv"},{"type":"text","value":"\n🌎 He is the former Board Chair of Groundswell International, is a trustee for the South Downs National Park Trust, and serves on the Rewilding Leadership Council for the Rewilding Institute.","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"key":"et0sYPkqs6"},{"type":"break","key":"MJkZTFGQg8"},{"type":"text","value":"\n🌎 Vance received his M.S. in Forest Science and Natural Resources Management from Cornell University and a B.A. in Biology from the College of Wooster. He is fluent in English, Spanish, QGIS, ArcGIS Pro, Geospatial Python, Google Earth Engine, Collaboration, and Conservation Science.","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"key":"Msq6rzP6sd"}],"key":"jiId8V9uRR"}],"key":"WQqPOlHTnX"}],"key":"gNUIkFCNEW"},"references":{"cite":{"order":[],"data":{}}}}