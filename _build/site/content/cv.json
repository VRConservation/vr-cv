1},"end":{"line":8,"column":1}},"children":[{"type":"strong","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"Conservation Consultant, ","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"hp3I3QgOFH"},{"type":"link","url":"http://3point.xyz","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"3point.xyz","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"v7kOLhVegV"}],"urlSource":"http://3point.xyz","key":"gatoKT6pFq"}],"key":"xODegAq6qu"},{"type":"text","value":". 2016-present. Providing a variety of services locally and internationally, including climate change adaptation strategies, wildlands plans, rewilding, technological solutions to managing land, geospatial data analysis, habitat restoration, sustainable forest management, project management, agricultural-environment scheme planning/evaluation, and innovative approaches to landscape-scale conservation.","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"uAvH5dtYYf"}],"key":"km9VKGX2Ld"},{"type":"paragraph","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"strong","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"California Director, National Forest Foundation","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"NHEp1KVQUd"}],"key":"avMJw7KyU2"},{"type":"text","value":". 2010-2016. Created vision and strategy and led multiple landscape-scale projects to restore and connect people to national forests. Funded, designed, and implemented additional sustainable conservation funds, greenhouse gas reduction projects, and collaboratives working with agencies, non-profits, the private sector, and foundations.","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"OfQCYEqJEw"}],"key":"kmZT0DURMX"},{"type":"paragraph","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"strong","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"text","value":"Director, Landowner Stewardship Program, Audubon California","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"xUkyzHeSNZ"}],"key":"ueKlKvJPni"},{"type":"text","value":". 2002-2010. Led program and managed projects that implemented restoration, research, conservation, and education projects in a manner compatible with existing agricultural land use practices. In addition, managed the Audubon Bobcat Ranch and Mayacamas Mountain Preserve.","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"dSu5ZdKf69"}],"key":"ajdOsnMRbF"},{"type":"paragraph","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"strong","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"text","value":"Senior Resource Planner, Kleinschmidt","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"key":"O45CmBYtyf"}],"key":"f1QNFg8TGS"},{"type":"text","value":". 2000-2002. Managed environmental planning, permitting, and implementation projects, including projects with CALFED Ecosystem Restoration Program, California Wilderness Coalition, The Nature Conservancy, Solano Irrigation District Habitat Conservation Plan, Department of Fish and Game, and US Fish and Wildlife Service.","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"key":"GBl19y1kc9"}],"key":"DfYxTjhi8i"},{"type":"paragraph","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"strong","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"text","value":"Program Officer, World Wildlife Fund","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"P0zncljEpU"}],"key":"MZuRRNS6Z9"},{"type":"text","value":". 1997-2000. Biodiversity Support Program, Analysis and Adaptive Management, and Latin America and Caribbean Programs. Managed multiple projects, including coalition building for conservation, the impact of sustainable agriculture on conservation, Latin American and Caribbean conservation portfolio, and Latin American biodiversity funding analysis.","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"eG0p5s3RvG"}],"key":"AcV4I6BLTJ"},{"type":"paragraph","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"strong","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"text","value":"Consultant, The Nature Conservancy","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"JJH4mAkBDB"}],"key":"weizaSSMH0"},{"type":"text","value":". 1997. Developed biodiversity and human ecological analysis tools for site conservation plans with conservation partners in the field for the Latin America and Caribbean Program.","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"NzijE2iEKM"}],"key":"U4EJrvt22S"},{"type":"paragraph","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"children":[{"type":"strong","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"children":[{"type":"text","value":"CBNRM Specialist, Center for the Environment, Cornell University","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"etZQm7P81N"}],"key":"P7PZnY0CWY"},{"type":"text","value":". 1993-1996. Community-Based Natural Resource Management Specialist. Developed biodiversity and human ecological analysis tools for site conservation plans with conservation partners in the field for the Latin America and Caribbean Program.  Led training and managed protected area conflict management projects.","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"Z3InGv933d"}],"key":"ErkRqgq0w9"},{"type":"paragraph","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"children":[{"type":"strong","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"children":[{"type":"text","value":"Assistant Director, Trainer, Recruiter & Volunteer, Peace Corps","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"JhKcPDFCgF"}],"key":"SlZ5H9uh5P"},{"type":"text","value":". 1987-1995. Provided program management a& leadership for the Peace Corps Bolivia National Parks & Bio-inventory Program, Managed projects focused on reforestation and farmer-to-farmer extension as an Agriculture and Forestry Extensionist in Honduras and Bolivia.","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"IJJ57ky8L2"}],"key":"weI5xLSkAI"},{"type":"heading","depth":2,"position":{"start":{"line":24,"column":1},"end":{"line":24,"column":1}},"children":[{"type":"text","value":"Education","position":{"start":{"line":24,"column":1},"end":{"line":24,"column":1}},"key":"XScVhTbYvf"}],"identifier":"education","label":"Education","html_id":"education","implicit":true,"key":"hsFvQWScBP"},{"type":"paragraph","position":{"start":{"line":26,"column":1},"end":{"line":26,"column":1}},"children":[{"type":"strong","position":{"start":{"line":26,"column":1},"end":{"line":26,"column":1}},"children":[{"type":"text","value":"Cornell University","position":{"start":{"line":26,"column":1},"end":{"line":26,"column":1}},"key":"K0q8AlirCO"}],"key":"mLZkMhEWln"},{"type":"text","value":". 1994-1996. M.S. Natural Resource Management and Forest Science. Minor in Conservation Biology and Sustainable Development.","position":{"start":{"line":26,"column":1},"end":{"line":26,"column":1}},"key":"nxLNja0lZy"}],"key":"GiUyRZATbE"},{"type":"paragraph","position":{"start":{"line":28,"column":1},"end":{"line":28,"column":1}